    vi.spyOn(TiendaService, 'getCalcetines').mockResolvedValue({
      data: cfalso,
    } as AxiosResponse)

    const respuesta = await TiendaService.getCalcetines('5')

    expect(respuesta.data).toEqual(cfalso)
  })
})
